# =====================================================================
# EuroTruck — .env.example (complet)
# Généré depuis l'audit config. Les SECRETS sont vides = à remplir.
# Les paramètres "AVANCÉS" ont des défauts sains — NE PAS tuner pendant
# la phase d'observation (zéro tuning avant 100+ trades clôturés).
# =====================================================================

# ---------- MetaTrader 5 (REQUIS) ----------
MT5_LOGIN=0
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=
MT5_INIT_RETRIES=10
MT5_INIT_RETRY_DELAY_SECONDS=30

# ---------- Secrets — livraison & backend (REQUIS pour le pipeline complet) ----------
# Sans ceux-là : pas de signal Telegram, pas d'annotation LLM, backend non authentifié.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
GROQ_API_KEY=
API_SECRET_TOKEN=
BACKEND_WEBHOOK_URL=
WEBHOOK_HMAC_SECRET=

# ---------- Backend (FastAPI) ----------
DATABASE_URL=sqlite:///./alerts.db
PORT=8000

# ---------- Détecteur — cœur ----------
SYMBOL=EURUSDm
# PIP_OVERRIDE=            # laisser vide : résolu depuis le symbole au démarrage
SCAN_INTERVAL_SECONDS=30
ENABLED_KILLZONES=LONDON,NY_AM
HEARTBEAT_MINUTES=15
LOG_LEVEL=INFO

# ---------- Tracker (cycle de vie des trades) ----------
# Use an absolute path in production multi-process deployments.
TRACKER_DB_PATH=data/eurotruck.db
TRACKER_TICK_SECONDS=30
PARTIAL_TP_FRACTION=0.5
# TRADE_MAX_AGE_HOURS=48  # (à ajouter via SPEC 16c — timeout anti-zombie)

# ---------- News / LLM (annotation ; non bloquant par défaut) ----------
HARD_BLOCK_RED_NEWS=false
BLOCK_ORANGE_NEWS=false
NEWS_RED_BLOCK_WINDOW_MIN=15
NEWS_ORANGE_BLOCK_WINDOW_MIN=5
NEWS_REFRESH_MINUTES=5
NEWS_WATCHED_CURRENCIES=USD,EUR
LLM_TIMEOUT_SECONDS=5

# =====================================================================
# AVANCÉ — seuils par setup. Défauts = hypothèses de départ.
# Ne pas modifier pendant l'observation.
# =====================================================================

# OTE / Fib partagés
OTE_ENTRY_TOLERANCE_PIPS=1.0

# London Judas
ASIA_SESSION_START_UTC=0
ASIA_SESSION_END_UTC=6
LONDON_JUDAS_LOOKBACK_M5=12
LONDON_JUDAS_MIN_RANGE_PIPS=15
LONDON_JUDAS_MIN_RISK_PIPS=5

# OTE Continuation
OTE_CONT_MIN_IMPULSE_PIPS=25
OTE_CONT_MIN_RISK_PIPS=5
OTE_CONT_BIAS_EMA=20

# PDH/PDL Sweep
PDH_PDL_LOOKBACK_M5=24
PDH_PDL_WICK_BODY_RATIO_MAX=0.5
PDH_PDL_MIN_RISK_PIPS=5

# Silver Bullet
SILVER_BULLET_NY_START_HOUR=10
SILVER_BULLET_NY_END_HOUR=11
SILVER_BULLET_MIN_RISK_PIPS=4

# Overlap BOS
OVERLAP_BOS_NY_START_HOUR=8
OVERLAP_BOS_NY_END_HOUR=10
OVERLAP_BOS_FIB_LOW=0.5
OVERLAP_BOS_FIB_HIGH=0.79
OVERLAP_BOS_MIN_RISK_PIPS=6

# Breaker Flip
BREAKER_LOOKBACK_M5=50
BREAKER_RETEST_TOLERANCE_PIPS=1
BREAKER_MIN_RISK_PIPS=5
BREAKER_REQUIRE_H1_BIAS_ALIGN=false


